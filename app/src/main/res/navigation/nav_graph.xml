<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/chatListFragment">

    <fragment
        android:id="@+id/chatListFragment"
        android:name="com.example.emsaide.ui.ChatListFragment"
        android:label="@string/chat_list"
        tools:layout="@layout/fragment_chat_list">
        
        <action
            android:id="@+id/action_chatList_to_emailSettings"
            app:destination="@id/emailSettingsFragment" />
        
        <action
            android:id="@+id/action_chatList_to_chatDetail"
            app:destination="@id/chatDetailFragment" />
            
    </fragment>

    <fragment
        android:id="@+id/emailSettingsFragment"
        android:name="com.example.emsaide.ui.EmailSettingsFragment"
        android:label="@string/email_settings"
        tools:layout="@layout/fragment_email_settings">
        
        <argument
            android:name="accountId"
            app:argType="long"
            android:defaultValue="-1L" />
            
    </fragment>

    <fragment
        android:id="@+id/chatDetailFragment"
        android:name="com.example.emsaide.ui.ChatDetailFragment"
        android:label="@string/settings"
        tools:layout="@layout/fragment_chat_detail">
        
        <argument
            android:name="accountId"
            app:argType="long"
            android:defaultValue="-1L" />
            
    </fragment>

</navigation>
